# ══════════════════════════════════════════════════════════════════════════════
# Navi Mumbai Property Deals — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000
BASE_URL=http://navimumbaipropertydeals
API_URL=http://navimumbaipropertydeals/api

# CORS
# Your Next.js frontend origin (no trailing slash)
CORS_ORIGIN=http://localhost:3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=navi_mumbai_property_deals

# JWT
# Use a long, random, secret string (min 32 chars recommended)
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# Cloudinary
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (SMTP) — Optional, for future email notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=Navi Mumbai Property Deals
